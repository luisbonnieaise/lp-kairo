# ── Público (browser) ────────────────────────────────────────────────────────
# URL canônica usada em metadata e sitemap. Em produção: https://kairoapp.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Links das lojas (placeholders — substituir quando o app for publicado)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/kairo
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=app.kairo

# Supabase — MESMO projeto/identidade do app Flutter. Só valores PÚBLICOS aqui
# (protegidos por RLS). A service role NUNCA entra na LP.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Servidor (somente backend — NUNCA com prefixo NEXT_PUBLIC) ───────────────
# Chave secreta da Stripe. A rota /api/checkout a usa para criar a Checkout
# Session. ⚠️ NUNCA commitar uma chave real — configure nos Environment
# Variables da Vercel. Rotacione imediatamente qualquer chave que tenha vazado.
STRIPE_SECRET_KEY=sk_test_xxx

# Price ids recorrentes (1 produto, 6 prices = 3 moedas × 2 períodos).
# A moeda é resolvida pelo locale: pt→BRL, en→USD, es/de→EUR.
# O trial de 7 dias vem do código (trial_period_days), não do price.
STRIPE_PRICE_BRL_MONTHLY=
STRIPE_PRICE_BRL_YEARLY=
STRIPE_PRICE_USD_MONTHLY=
STRIPE_PRICE_USD_YEARLY=
STRIPE_PRICE_EUR_MONTHLY=
STRIPE_PRICE_EUR_YEARLY=
