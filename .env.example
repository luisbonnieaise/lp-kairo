# URL canônica usada em metadata, sitemap e nas URLs de retorno do checkout.
# Em produção, defina como https://thekairo.app (sempre https).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Links das lojas (placeholders — substituir quando o app for publicado)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/kairo
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=app.kairo

# Supabase — gate de login pré-checkout (mesmo projeto/auth.users do app).
# Anon key é pública por design; service role NUNCA entra na LP.
NEXT_PUBLIC_SUPABASE_URL=https://ojagemcqbekonwqjidkp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — SERVER-SIDE (sem NEXT_PUBLIC; nunca chegam ao browser).
# A rota /api/checkout resolve o price por (moeda do locale × período):
# pt→BRL, en→USD, es/de→EUR. Ver kairos/docs/08-guia-consoles-luis.md §1.
STRIPE_SECRET_KEY=
STRIPE_PRICE_BRL_MONTHLY=
STRIPE_PRICE_BRL_YEARLY=
STRIPE_PRICE_USD_MONTHLY=
STRIPE_PRICE_USD_YEARLY=
STRIPE_PRICE_EUR_MONTHLY=
STRIPE_PRICE_EUR_YEARLY=
