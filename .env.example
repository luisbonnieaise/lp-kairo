# URL canônica usada em metadata e sitemap. Em produção, defina como https://kairoapp.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Links das lojas (placeholders — substituir quando o app for publicado)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/kairo
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=app.kairo

# Stripe Payment Links — um por moeda × período (6 no total).
# Cada locale resolve a moeda automaticamente: pt→BRL, en→USD, es/de→EUR.
NEXT_PUBLIC_STRIPE_LINK_BRL_MONTHLY=
NEXT_PUBLIC_STRIPE_LINK_BRL_YEARLY=
NEXT_PUBLIC_STRIPE_LINK_USD_MONTHLY=
NEXT_PUBLIC_STRIPE_LINK_USD_YEARLY=
NEXT_PUBLIC_STRIPE_LINK_EUR_MONTHLY=
NEXT_PUBLIC_STRIPE_LINK_EUR_YEARLY=
